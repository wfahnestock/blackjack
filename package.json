{
  "name": "blackjack-react",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:app -- --host\" \"npm run dev:server\"",
    "dev:app": "react-router dev",
    "dev:server": "tsx watch server/index.ts",
    "build": "react-router build",
    "start": "react-router-serve ./server/index.js",
    "typecheck": "react-router typegen && tsc",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.2",
    "isbot": "^5.1.31",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.0.9",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.19.3",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
